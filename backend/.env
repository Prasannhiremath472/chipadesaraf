NODE_ENV=development
PORT=5000

FRONTEND_URL=http://localhost:5173

# ── Database ── fill in your MySQL credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aurae_jewellery

# ── JWT ──
JWT_SECRET=aurae_dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=aurae_dev_refresh_secret_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (leave blank to skip emails in dev) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@aurae.in
FROM_NAME=Auraè Jewellery

# ── Razorpay (test keys) ──
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# ── Misc ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
BCRYPT_ROUNDS=12
OTP_EXPIRES_MINUTES=10
