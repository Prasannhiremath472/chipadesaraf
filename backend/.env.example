# ─────────────────────────────────────────
#  Auraè Backend — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in values

# Server
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
#  Database (MySQL)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=aurae_jewellery

# ─────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=another_very_long_random_string_for_refresh_tokens
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
#  Email (SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@aurae.in
FROM_NAME=Auraè Jewellery

# ─────────────────────────────────────────
#  Razorpay
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
#  File Upload
# ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─────────────────────────────────────────
#  Misc
# ─────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_EXPIRES_MINUTES=10
